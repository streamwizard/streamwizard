{
  "title": "StreamWizard — Service Observability",
  "description": "Full-stack observability: HTTP API, WebSocket server, Twitch EventSub & API, Supabase",
  "tags": ["streamwizard", "observability"],
  "editable": true,
  "liveNow": false,
  "preload": false,
  "cursorSync": "Crosshair",
  "links": [],
  "annotations": [
    {
      "builtIn": 1,
      "datasource": { "type": "grafana", "uid": "-- Grafana --" },
      "enable": true,
      "hide": true,
      "iconColor": "rgba(0, 211, 255, 1)",
      "name": "Annotations & Alerts",
      "type": "dashboard"
    }
  ],
  "timeSettings": {
    "from": "now-1h",
    "to": "now",
    "timezone": "browser",
    "autoRefresh": "30s",
    "autoRefreshIntervals": ["10s", "30s", "1m", "5m", "15m", "1h"],
    "fiscalYearStartMonth": 0,
    "hideTimepicker": false
  },
  "variables": [
    {
      "kind": "DatasourceVariable",
      "spec": {
        "current": {},
        "hide": "dontHide",
        "includeAll": false,
        "label": "InfluxDB",
        "name": "datasource",
        "options": [],
        "pluginId": "influxdb",
        "refresh": "onDashboardLoad"
      }
    },
    {
      "kind": "ConstantVariable",
      "spec": {
        "name": "bucket",
        "label": "Bucket",
        "value": "streamwizard-prod",
        "hide": "dontHide"
      }
    }
  ],
  "elements": {

    "panel-logo": {
      "kind": "Panel",
      "spec": {
        "id": 1,
        "title": "",
        "transparent": true,
        "vizConfig": {
          "kind": "text",
          "spec": {
            "options": {
              "mode": "html",
              "content": "<div style=\"display:flex;align-items:center;justify-content:center;height:100%;\">\n  <svg width=\"64\" height=\"64\" viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n    <defs>\n      <linearGradient id=\"hatGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n        <stop offset=\"0%\" stop-color=\"#BF94FF\"/>\n        <stop offset=\"100%\" stop-color=\"#772CE8\"/>\n      </linearGradient>\n    </defs>\n    <polygon points=\"32,4 11,58 53,58\" fill=\"url(#hatGrad)\"/>\n    <ellipse cx=\"32\" cy=\"58\" rx=\"22\" ry=\"5\" fill=\"#5c16c5\"/>\n    <ellipse cx=\"32\" cy=\"58\" rx=\"22\" ry=\"5\" fill=\"none\" stroke=\"#BF94FF\" stroke-width=\"1\"/>\n    <circle cx=\"32\" cy=\"24\" r=\"2.5\" fill=\"#FFD700\"/>\n    <circle cx=\"26\" cy=\"18\" r=\"1.5\" fill=\"#FFD700\" opacity=\"0.6\"/>\n    <circle cx=\"38\" cy=\"19\" r=\"1.5\" fill=\"#FFD700\" opacity=\"0.6\"/>\n    <line x1=\"53\" y1=\"30\" x2=\"62\" y2=\"30\" stroke=\"#00D4FF\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n    <line x1=\"53\" y1=\"37\" x2=\"64\" y2=\"37\" stroke=\"#00D4FF\" stroke-width=\"2.5\" stroke-linecap=\"round\" opacity=\"0.6\"/>\n    <line x1=\"53\" y1=\"44\" x2=\"61\" y2=\"44\" stroke=\"#00D4FF\" stroke-width=\"2.5\" stroke-linecap=\"round\" opacity=\"0.3\"/>\n  </svg>\n</div>"
            }
          }
        },
        "data": { "kind": "QueryGroup", "spec": { "queries": [], "transformations": [] } }
      }
    },

    "panel-header": {
      "kind": "Panel",
      "spec": {
        "id": 2,
        "title": "",
        "transparent": true,
        "vizConfig": {
          "kind": "text",
          "spec": {
            "options": {
              "mode": "html",
              "content": "<div style=\"display:flex;flex-direction:column;justify-content:center;height:100%;padding:4px 0 4px 12px;\">\n  <div style=\"font-size:28px;font-weight:700;letter-spacing:-0.5px;color:#ffffff;line-height:1.2;\">StreamWizard</div>\n  <div style=\"font-size:12px;color:#888;margin-top:6px;letter-spacing:0.8px;text-transform:uppercase;\">Service Observability &nbsp;&nbsp;·&nbsp;&nbsp; HTTP &nbsp;·&nbsp; WebSocket &nbsp;·&nbsp; EventSub &nbsp;·&nbsp; Supabase</div>\n</div>"
            }
          }
        },
        "data": { "kind": "QueryGroup", "spec": { "queries": [], "transformations": [] } }
      }
    },

    "row-platform-health": {
      "kind": "Panel",
      "spec": {
        "id": 100,
        "title": "Platform Health",
        "vizConfig": { "kind": "row", "spec": { "options": { "collapsed": false } } },
        "data": { "kind": "QueryGroup", "spec": { "queries": [], "transformations": [] } }
      }
    },

    "panel-api-requests": {
      "kind": "Panel",
      "spec": {
        "id": 3,
        "title": "API Requests",
        "description": "Total HTTP requests in the selected time range.",
        "vizConfig": {
          "kind": "stat",
          "spec": {
            "options": {
              "reduceOptions": { "calcs": ["sum"] },
              "colorMode": "background_solid",
              "graphMode": "area",
              "textMode": "auto",
              "justifyMode": "center",
              "orientation": "auto"
            },
            "fieldConfig": {
              "defaults": {
                "displayName": "Requests",
                "noValue": "0",
                "color": { "mode": "fixed", "fixedColor": "semi-dark-blue" },
                "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "semi-dark-blue" }] }
              },
              "overrides": []
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"http_request\" and r[\"_field\"] == \"duration_ms\")\n  |> count()\n  |> sum()" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "panel-avg-latency": {
      "kind": "Panel",
      "spec": {
        "id": 4,
        "title": "Avg Response Time",
        "description": "Average HTTP response latency. Green < 200ms, orange < 1s, red above.",
        "vizConfig": {
          "kind": "stat",
          "spec": {
            "options": {
              "reduceOptions": { "calcs": ["mean"] },
              "colorMode": "background_solid",
              "graphMode": "area",
              "textMode": "auto",
              "justifyMode": "center",
              "orientation": "auto"
            },
            "fieldConfig": {
              "defaults": {
                "displayName": "Avg Latency",
                "unit": "ms",
                "decimals": 1,
                "noValue": "—",
                "color": { "mode": "thresholds" },
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    { "value": null, "color": "semi-dark-green"  },
                    { "value": 200,  "color": "semi-dark-orange" },
                    { "value": 1000, "color": "semi-dark-red"    }
                  ]
                }
              },
              "overrides": []
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"http_request\" and r[\"_field\"] == \"duration_ms\")\n  |> mean()" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "panel-http-errors": {
      "kind": "Panel",
      "spec": {
        "id": 5,
        "title": "HTTP Errors",
        "description": "Count of 4xx and 5xx responses. Should stay near 0.",
        "vizConfig": {
          "kind": "stat",
          "spec": {
            "options": {
              "reduceOptions": { "calcs": ["sum"] },
              "colorMode": "background_solid",
              "graphMode": "area",
              "textMode": "auto",
              "justifyMode": "center",
              "orientation": "auto"
            },
            "fieldConfig": {
              "defaults": {
                "displayName": "Errors",
                "noValue": "0",
                "color": { "mode": "thresholds" },
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    { "value": null, "color": "semi-dark-green"  },
                    { "value": 1,    "color": "semi-dark-orange" },
                    { "value": 10,   "color": "semi-dark-red"    }
                  ]
                }
              },
              "overrides": []
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"http_request\" and r[\"_field\"] == \"duration_ms\")\n  |> filter(fn: (r) => r[\"status\"] =~ /^[45]/)\n  |> count()\n  |> sum()" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "panel-ws-messages": {
      "kind": "Panel",
      "spec": {
        "id": 6,
        "title": "WS Messages",
        "description": "Total WebSocket messages processed across all roles.",
        "vizConfig": {
          "kind": "stat",
          "spec": {
            "options": {
              "reduceOptions": { "calcs": ["sum"] },
              "colorMode": "background_solid",
              "graphMode": "area",
              "textMode": "auto",
              "justifyMode": "center",
              "orientation": "auto"
            },
            "fieldConfig": {
              "defaults": {
                "displayName": "Messages",
                "noValue": "0",
                "color": { "mode": "fixed", "fixedColor": "semi-dark-purple" },
                "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "semi-dark-purple" }] }
              },
              "overrides": []
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"ws_message\" and r[\"_field\"] == \"count\")\n  |> sum()" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "panel-eventsub-events": {
      "kind": "Panel",
      "spec": {
        "id": 7,
        "title": "EventSub Events",
        "description": "Total Twitch EventSub events received.",
        "vizConfig": {
          "kind": "stat",
          "spec": {
            "options": {
              "reduceOptions": { "calcs": ["sum"] },
              "colorMode": "background_solid",
              "graphMode": "area",
              "textMode": "auto",
              "justifyMode": "center",
              "orientation": "auto"
            },
            "fieldConfig": {
              "defaults": {
                "displayName": "Events",
                "noValue": "0",
                "color": { "mode": "fixed", "fixedColor": "dark-purple" },
                "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "dark-purple" }] }
              },
              "overrides": []
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"eventsub_event\" and r[\"_field\"] == \"count\")\n  |> sum()" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "panel-db-latency": {
      "kind": "Panel",
      "spec": {
        "id": 8,
        "title": "DB Avg Latency",
        "description": "Average Supabase query duration. Green < 100ms, orange < 500ms, red above.",
        "vizConfig": {
          "kind": "stat",
          "spec": {
            "options": {
              "reduceOptions": { "calcs": ["mean"] },
              "colorMode": "background_solid",
              "graphMode": "area",
              "textMode": "auto",
              "justifyMode": "center",
              "orientation": "auto"
            },
            "fieldConfig": {
              "defaults": {
                "displayName": "DB Latency",
                "unit": "ms",
                "decimals": 1,
                "noValue": "—",
                "color": { "mode": "thresholds" },
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    { "value": null, "color": "semi-dark-green"  },
                    { "value": 100,  "color": "semi-dark-orange" },
                    { "value": 500,  "color": "semi-dark-red"    }
                  ]
                }
              },
              "overrides": []
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"supabase_query\" and r[\"_field\"] == \"duration_ms\")\n  |> mean()" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "row-http-api": {
      "kind": "Panel",
      "spec": {
        "id": 101,
        "title": "HTTP API",
        "vizConfig": { "kind": "row", "spec": { "options": { "collapsed": false } } },
        "data": { "kind": "QueryGroup", "spec": { "queries": [], "transformations": [] } }
      }
    },

    "panel-request-throughput": {
      "kind": "Panel",
      "spec": {
        "id": 10,
        "title": "Request Throughput by Route",
        "description": "HTTP requests per window, grouped by route.",
        "vizConfig": {
          "kind": "timeseries",
          "spec": {
            "options": {
              "tooltip": { "mode": "multi", "sort": "desc" },
              "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"], "showLegend": true }
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short",
                "min": 0,
                "color": { "mode": "palette-classic" },
                "custom": {
                  "drawStyle": "bars",
                  "lineWidth": 1,
                  "fillOpacity": 70,
                  "gradientMode": "none",
                  "spanNulls": false,
                  "showPoints": "never",
                  "stacking": { "mode": "normal", "group": "A" },
                  "barAlignment": 0
                }
              },
              "overrides": []
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"http_request\" and r[\"_field\"] == \"duration_ms\")\n  |> aggregateWindow(every: v.windowPeriod, fn: count, createEmpty: false)\n  |> group(columns: [\"route\"])\n  |> map(fn: (r) => ({ r with _field: r.route }))\n  |> yield(name: \"throughput\")" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "panel-response-latency": {
      "kind": "Panel",
      "spec": {
        "id": 11,
        "title": "Response Latency by Route",
        "description": "Average response time per route per window. Threshold markers at 200ms and 1s.",
        "vizConfig": {
          "kind": "timeseries",
          "spec": {
            "options": {
              "tooltip": { "mode": "multi", "sort": "desc" },
              "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"], "showLegend": true }
            },
            "fieldConfig": {
              "defaults": {
                "unit": "ms",
                "decimals": 1,
                "min": 0,
                "color": { "mode": "palette-classic" },
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    { "value": null, "color": "green"  },
                    { "value": 200,  "color": "yellow" },
                    { "value": 1000, "color": "red"    }
                  ]
                },
                "custom": {
                  "drawStyle": "line",
                  "lineInterpolation": "smooth",
                  "lineWidth": 2,
                  "fillOpacity": 12,
                  "gradientMode": "opacity",
                  "spanNulls": false,
                  "showPoints": "never",
                  "thresholdsStyle": { "mode": "dashed" }
                }
              },
              "overrides": []
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"http_request\" and r[\"_field\"] == \"duration_ms\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> group(columns: [\"route\"])\n  |> map(fn: (r) => ({ r with _field: r.route }))\n  |> yield(name: \"avg_latency\")" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "row-websocket": {
      "kind": "Panel",
      "spec": {
        "id": 102,
        "title": "WebSocket Server",
        "vizConfig": { "kind": "row", "spec": { "options": { "collapsed": false } } },
        "data": { "kind": "QueryGroup", "spec": { "queries": [], "transformations": [] } }
      }
    },

    "panel-ws-connections": {
      "kind": "Panel",
      "spec": {
        "id": 12,
        "title": "Connection Activity",
        "description": "WebSocket open/close events over time, split by role (publisher, subscriber, bot).",
        "vizConfig": {
          "kind": "timeseries",
          "spec": {
            "options": {
              "tooltip": { "mode": "multi", "sort": "desc" },
              "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"], "showLegend": true }
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short",
                "min": 0,
                "color": { "mode": "palette-classic" },
                "custom": {
                  "drawStyle": "bars",
                  "lineWidth": 1,
                  "fillOpacity": 70,
                  "gradientMode": "none",
                  "spanNulls": false,
                  "showPoints": "never",
                  "barAlignment": 0
                }
              },
              "overrides": []
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"ws_connection\" and r[\"_field\"] == \"count\")\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.role + \" — \" + r.event }))\n  |> yield(name: \"connections\")" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "panel-ws-message-throughput": {
      "kind": "Panel",
      "spec": {
        "id": 13,
        "title": "Message Throughput",
        "description": "WebSocket messages per window, broken down by role and message type.",
        "vizConfig": {
          "kind": "timeseries",
          "spec": {
            "options": {
              "tooltip": { "mode": "multi", "sort": "desc" },
              "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"], "showLegend": true }
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short",
                "min": 0,
                "color": { "mode": "palette-classic" },
                "custom": {
                  "drawStyle": "line",
