                  "fillOpacity": 12,
                  "gradientMode": "opacity",
                  "spanNulls": false,
                  "showPoints": "never"
                }
              },
              "overrides": []
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"ws_message\" and r[\"_field\"] == \"count\")\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.role + \" — \" + r.message_type }))\n  |> yield(name: \"messages\")" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "row-twitch": {
      "kind": "Panel",
      "spec": {
        "id": 103,
        "title": "Twitch EventSub & API",
        "vizConfig": { "kind": "row", "spec": { "options": { "collapsed": false } } },
        "data": { "kind": "QueryGroup", "spec": { "queries": [], "transformations": [] } }
      }
    },

    "panel-eventsub-stream": {
      "kind": "Panel",
      "spec": {
        "id": 14,
        "title": "EventSub — Events by Type",
        "description": "EventSub events per window grouped by type. Revocations shown in red.",
        "vizConfig": {
          "kind": "timeseries",
          "spec": {
            "options": {
              "tooltip": { "mode": "multi", "sort": "desc" },
              "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"], "showLegend": true }
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short",
                "min": 0,
                "color": { "mode": "palette-classic" },
                "custom": {
                  "drawStyle": "line",
                  "lineInterpolation": "smooth",
                  "lineWidth": 2,
                  "fillOpacity": 12,
                  "gradientMode": "opacity",
                  "spanNulls": false,
                  "showPoints": "never"
                }
              },
              "overrides": [
                {
                  "matcher": { "id": "byRegexp", "options": "/^revoked:/" },
                  "properties": [
                    { "id": "color.mode",         "value": "fixed"         },
                    { "id": "color.fixedColor",   "value": "semi-dark-red" },
                    { "id": "custom.drawStyle",   "value": "bars"          },
                    { "id": "custom.fillOpacity", "value": 60              }
                  ]
                }
              ]
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"eventsub_event\" and r[\"_field\"] == \"count\")\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)\n  |> group(columns: [\"event_type\", \"handled\"])\n  |> map(fn: (r) => ({ r with _field: r.event_type + \" (handled=\" + r.handled + \")\" }))\n  |> yield(name: \"events\")" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              },
              {
                "kind": "DataQuery",
                "spec": { "refId": "B", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"eventsub_revocation\" and r[\"_field\"] == \"count\")\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)\n  |> group(columns: [\"event_type\"])\n  |> map(fn: (r) => ({ r with _field: \"revoked: \" + r.event_type }))\n  |> yield(name: \"revocations\")" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "panel-twitch-api-requests": {
      "kind": "Panel",
      "spec": {
        "id": 15,
        "title": "Twitch API — Requests by Endpoint",
        "description": "Twitch API request count per window, grouped by endpoint and HTTP status.",
        "vizConfig": {
          "kind": "timeseries",
          "spec": {
            "options": {
              "tooltip": { "mode": "multi", "sort": "desc" },
              "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"], "showLegend": true }
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short",
                "min": 0,
                "color": { "mode": "palette-classic" },
                "custom": {
                  "drawStyle": "line",
                  "lineInterpolation": "smooth",
                  "lineWidth": 2,
                  "fillOpacity": 12,
                  "gradientMode": "opacity",
                  "spanNulls": false,
                  "showPoints": "never"
                }
              },
              "overrides": [
                {
                  "matcher": { "id": "byRegexp", "options": "/\\[4|\\[5/" },
                  "properties": [
                    { "id": "color.mode",       "value": "fixed"         },
                    { "id": "color.fixedColor", "value": "semi-dark-red" }
                  ]
                }
              ]
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"twitch_api_request\" and r[\"_field\"] == \"count\")\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)\n  |> group(columns: [\"endpoint\", \"status\"])\n  |> map(fn: (r) => ({ r with _field: r.endpoint + \" [\" + r.status + \"]\" }))\n  |> yield(name: \"twitch_requests\")" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "row-supabase": {
      "kind": "Panel",
      "spec": {
        "id": 104,
        "title": "Supabase",
        "vizConfig": { "kind": "row", "spec": { "options": { "collapsed": false } } },
        "data": { "kind": "QueryGroup", "spec": { "queries": [], "transformations": [] } }
      }
    },

    "panel-db-query-latency": {
      "kind": "Panel",
      "spec": {
        "id": 16,
        "title": "Query Latency by Table & Operation",
        "description": "Average Supabase query duration per window. Each series is a table+operation pair.",
        "vizConfig": {
          "kind": "timeseries",
          "spec": {
            "options": {
              "tooltip": { "mode": "multi", "sort": "desc" },
              "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"], "showLegend": true, "width": 280 }
            },
            "fieldConfig": {
              "defaults": {
                "unit": "ms",
                "decimals": 1,
                "min": 0,
                "color": { "mode": "palette-classic" },
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    { "value": null, "color": "green"  },
                    { "value": 100,  "color": "yellow" },
                    { "value": 500,  "color": "red"    }
                  ]
                },
                "custom": {
                  "drawStyle": "line",
                  "lineInterpolation": "smooth",
                  "lineWidth": 2,
                  "fillOpacity": 10,
                  "gradientMode": "opacity",
                  "spanNulls": false,
                  "showPoints": "never",
                  "thresholdsStyle": { "mode": "dashed" }
                }
              },
              "overrides": []
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"supabase_query\" and r[\"_field\"] == \"duration_ms\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> group(columns: [\"table\", \"operation\"])\n  |> map(fn: (r) => ({ r with _field: r.table + \" — \" + r.operation }))\n  |> yield(name: \"query_latency\")" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    },

    "panel-db-query-volume": {
      "kind": "Panel",
      "spec": {
        "id": 17,
        "title": "Query Volume & Errors",
        "description": "Supabase queries per window. Successful queries in green, failures in red.",
        "vizConfig": {
          "kind": "timeseries",
          "spec": {
            "options": {
              "tooltip": { "mode": "multi", "sort": "desc" },
              "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"], "showLegend": true }
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short",
                "min": 0,
                "color": { "mode": "palette-classic" },
                "custom": {
                  "drawStyle": "bars",
                  "lineWidth": 1,
                  "fillOpacity": 70,
                  "gradientMode": "none",
                  "spanNulls": false,
                  "showPoints": "never",
                  "stacking": { "mode": "normal", "group": "A" },
                  "barAlignment": 0
                }
              },
              "overrides": [
                {
                  "matcher": { "id": "byName", "options": "error" },
                  "properties": [
                    { "id": "color.mode",       "value": "fixed"          },
                    { "id": "color.fixedColor", "value": "semi-dark-red"  }
                  ]
                },
                {
                  "matcher": { "id": "byName", "options": "success" },
                  "properties": [
                    { "id": "color.mode",       "value": "fixed"           },
                    { "id": "color.fixedColor", "value": "semi-dark-green" }
                  ]
                }
              ]
            }
          }
        },
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "DataQuery",
                "spec": { "refId": "A", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"supabase_query\" and r[\"_field\"] == \"duration_ms\")\n  |> filter(fn: (r) => r[\"success\"] == \"true\")\n  |> aggregateWindow(every: v.windowPeriod, fn: count, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: \"success\" }))\n  |> yield(name: \"ok\")" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              },
              {
                "kind": "DataQuery",
                "spec": { "refId": "B", "query": "from(bucket: \"${bucket:raw}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"supabase_query\" and r[\"_field\"] == \"duration_ms\")\n  |> filter(fn: (r) => r[\"success\"] == \"false\")\n  |> aggregateWindow(every: v.windowPeriod, fn: count, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: \"error\" }))\n  |> yield(name: \"errors\")" },
                "datasource": { "type": "influxdb", "uid": "${datasource}" }
              }
            ],
            "transformations": []
          }
        }
      }
    }

  },
