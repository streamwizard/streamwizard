# ============================================================
# StreamWizard — Environment Variables
# Copy this file to .env and fill in your values.
# Local Supabase values are shown by running: supabase start
# ============================================================

# General
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────
# Local: http://127.0.0.1:54321 | Cloud: https://<project>.supabase.co
SUPABASE_URL=

# Anon/public key — safe to expose to the browser
# Local: printed by `supabase start` as "anon key"
SUPABASE_PUBLIC_KEY=

# Service role key — never expose this publicly
# Local: printed by `supabase start` as "service_role key"
SUPABASE_SECRET_KEY=

# ── Twitch ───────────────────────────────────────────────────
# Create an app at https://dev.twitch.tv/console
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Random string used to verify incoming EventSub webhook payloads
TWITCH_WEBHOOK_SECRET=

SUPABASE_AUTH_EXTERNAL_TWITCH_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_TWITCH_SECRET=

# EventSub conduit ID — created once via the Twitch API and reused
TWITCH_CONDUIT_ID=

# ── Token Encryption ─────────────────────────────────────────
# 32-byte hex string used to encrypt Twitch OAuth tokens at rest
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── Internal Service URLs ────────────────────────────────────
# WebSocket server base URL (e.g. ws://localhost:8000 locally)
WS_SERVER_URL=

# REST API base URL (e.g. http://localhost:3001 locally)
STREAMWIZARD_API_URL=

# ── Next.js Public URLs (web-streamwizard + web-overlay) ─────
# Publicly accessible base URL of the main dashboard
NEXT_PUBLIC_BASE_URL=

# Publicly accessible base URL of the overlay app
NEXT_PUBLIC_OVERLAY_URL=

# ── InfluxDB (web-monitor only) ───────────────────────────────
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=

# ── Monitor (optional) ───────────────────────────────────────
# Shared secret to protect the live WebSocket inspector
MONITOR_SECRET=

# ── Sentry (optional) ────────────────────────────────────────
SENTRY_DSN=
SENTRY_RELEASE=

# ── PostHog (optional) ───────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
