{
  "name": "twitch-tools",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:main": "turbo run dev --filter=@repo/web-streamwizard --filter=@repo/web-overlay --filter=@repo/streamwizard-bot --filter=@repo/ws-server --filter=@repo/web-monitor",
    "dev:monitor": "turbo run dev --filter=@repo/web-monitor",
    "doppler:sync": "bash scripts/sync-doppler-shared.sh",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "bun x turbo run check-types",
    "gen-types": "supabase gen types typescript --project-id jgxdrljoqployiyjedst --schema public > packages/supabase/src/types/supabase.ts"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.4",
    "typescript": "5.9.2"
  },
  "overrides": {
    "next": "^16.2.6",
    "@sentry/core": "10.56.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "server-only": "^0.0.1"
  }
}
